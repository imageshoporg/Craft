{% import "_includes/forms" as forms %}

{{ forms.autosuggestField({
    label: 'Token'|t('imageshop-dam'),
    instructions: 'Imageshop token'|t('imageshop-dam'),
    id: 'token',
    name: 'token',
    suggestEnvVars: true,
    required: true,
    value: settings['token']})
}}

{{ forms.autosuggestField({
    label: 'Key'|t('imageshop-dam'),
    instructions: 'Imageshop private key'|t('imageshop-dam'),
    id: 'key',
    name: 'key',
    suggestEnvVars: true,
    required: true,
    value: settings['key']})
}}

{% set languages = [
  {
    label: 'Norwegian'|t('imageshop-dam'),
    value: 'nb-NO'
  }, {
    label: 'English'|t('imageshop-dam'),
    value: 'en-US'
  }
] %}

{{ forms.selectField({
    label: 'Language'|t('imageshop-dam'),
    id: 'language',
    name: 'language',
    options: languages,
    value: settings['language']})
}}

{{ forms.selectField({
    label: 'Imageshop field used to generate opengraph image'|t('imageshop-dam'),
    instructions: 'This will work only if the SEOmatic plugin is installed. The field must be assigned to the element (such as an entry) for which you want to generate the OpenGraph image using Imageshop. The first image from the field will be used.'|t('imageshop-dam'),
    id: 'openGraphFieldId',
    name: 'openGraphFieldId',
    options: settings.getOpengraphFieldOptions(),
    value: settings.openGraphFieldId})
}}

{{ forms.selectField({
    label: 'Global set which will be used as source for the default opengraph image.'|t('imageshop-dam'),
    instructions: 'This will work only if the SEOmatic plugin is installed. This global must have imageshop field assigned and will be used only if current element does not have its own specific opengraph defined by its Imageshop field.'|t('imageshop-dam'),
    id: 'openGraphGlobalId',
    name: 'openGraphGlobalId',
    options: settings.getOpengraphGlobalOptions(),
    value: settings.openGraphGlobalId})
}}
