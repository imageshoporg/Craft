<form class="" method="post" accept-charset="UTF-8">

    {{ actionInput('imageshop-dam/default/create-sync-jobs') }}
    {{ csrfInput() }}
    {{ redirectInput('utilities/imageshop-dam') }}

    <div>
        {{ 'This will fetch the latest metadata from the Imageshop API and update all Imageshop fields in Craft, including alternative text, descriptions, credits, and tags.'|t('imageshop-dam') }}
        <br>
        <strong>
            {{ 'Important: This action cannot be undone. Manual edits to metadata will be overwritten.'|t('imageshop-dam') }}
        </strong>
    </div>

    <br>

    <div class="">
        <button type="submit" class="btn submit">{{ 'Sync metadata'|t('imageshop-dam') }}</button>
    </div>
</form>

<hr>

<h2>{{ 'Sync history'|t('imageshop-dam') }}</h2>

{% if syncLog is empty %}
    <p class="zilch">{{ 'No syncs have been run yet.'|t('imageshop-dam') }}</p>
{% else %}
    <table class="data fullwidth">
        <thead>
            <tr>
                <th>{{ 'Date'|t('imageshop-dam') }}</th>
                <th>{{ 'Documents changed'|t('imageshop-dam') }}</th>
                <th>{{ 'Jobs queued'|t('imageshop-dam') }}</th>
                <th>{{ 'Status'|t('imageshop-dam') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in syncLog %}
                <tr>
                    <td>{{ entry.dateCreated|date('short') }} {{ entry.dateCreated|time('short') }}</td>
                    <td>{{ entry.documentsChanged }}</td>
                    <td>{{ entry.jobsQueued }}</td>
                    <td>
                        {% if entry.status == 'success' %}
                            <span class="status green"></span> {{ 'Success'|t('imageshop-dam') }}
                        {% else %}
                            <span class="status light"></span> {{ 'No changes'|t('imageshop-dam') }}
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}
