{% import "_includes/forms" as forms %}


<div id="imageshop-{{ field.id }}" data-id="{{ namespace }}imageshop" data-current-language="{{ field.getCurrentAdminLanguage() }}">

    <div class="mb-2">
        <div class="imageshop-preview element removable large hasthum" data-imageshop-list>
            {% if value ?? false %}
                {% if value is array %}
                    {% include 'imageshop-dam/_components/fields/input-list.twig' with {
                        images: value,
                        language: field.getCurrentAdminLanguage(),
                    } %}
                {% else %}
                    {% if value.image %}
                        {% include 'imageshop-dam/_components/fields/input-list.twig' with {
                            images: [value.image],
                            language: field.getCurrentAdminLanguage(),
                        } %}
                    {% endif %}
                {% endif %}
            {% endif %}
        </div>
    </div>

    <button type="button" class="imageshop-trigger add icon dashed btn">{{ 'buttonText'|t('imageshop-dam') }}</button>
    {{ forms.hidden({
        id: id ~ namespace,
        name: name,
        value: valueArray|json_encode,
    })|attr({class: 'imageshop-value'}) }}
</div>

{% css %}
.imageshop-img-container{
    padding: 1rem;
    background-color: var(--gray-050);
    box-shadow: 0 2px 6px -1px rgba(0,0,0,.05);
    margin-bottom: 1rem;
}
.imageshop-label{
    margin-top: 0.5rem;
    font-weight: bold;
}
.imageshop-preview{
    width: 100%;
    display: flex !important;
    flex-wrap: wrap;
    gap: 1rem;
}
.imageshop-img-container{
    width: 230px;
    img{
        width: 100%;
        height: 100px;
        object-fit: contain;
    }
}
.imageshop-img-container__alt{
    margin-top: 0.5rem;
}
.imageshop-img-container{
    position: relative;
}

.imageshop-img-container__reorder{
    position: absolute;
    top: 1px;
    left: 5px;
}
.imageshop-img-container__remove{
    position: absolute;
    top: 0px !important;
    right: 5px !important;
}
{% endcss %}