{% import "_includes/forms" as forms %}

{# {{ forms.textField({
    label: 'Input text',
    instructions: 'Text on the selection button',
    name: 'buttonText',
    value: 'buttonText'|t('imageshop')
}) }} #}

{{ forms.textField({
    label: 'Sizes'|t('imageshop-plugin'),
    instructions: 'Predefined sizes the user can choose from.'|t('imageshop-plugin'),
    name: 'sizes',
    value: field['sizes']
}) }}

{{ forms.lightswitchField({
    label: 'Edit description before insert?'|t('imageshop-plugin'),
    instructions: 'Indicates whether the description field should be editable when inserting an image.'|t('imageshop-plugin'),
    name: 'showDescription',
    on: field['showDescription']
}) }}

{{ forms.lightswitchField({
    label: 'Show Crop Dialogue?'|t('imageshop-plugin'),
    instructions: 'Indicates whether the crop dialogue should be shown.'|t('imageshop-plugin'),
    name: 'showCropDialogue',
    on: field['showCropDialogue']
}) }}

{{ forms.lightswitchField({
    label: 'Show Size Dialogue?'|t('imageshop-plugin'),
    instructions: 'Indicates whether the size dialogue should be shown.'|t('imageshop-plugin'),
    name: 'showSizeDialogue',
    on: field['showSizeDialogue']
}) }}

{{ forms.lightswitchField({
    label: 'Allow multiple?'|t('imageshop-plugin'),
    instructions: 'Indicates whether the field should allow multiple images'|t('imageshop-plugin'),
    name: 'allowMultiple',
    on: field['allowMultiple']
}) }}