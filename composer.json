{
    "name": "imageshop/imageshop-dam",
    "description": "Imageshop DAM Integration for CraftCMS",
    "type": "craft-plugin",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "imageshop"
    ],
    "support": {
        "docs": "https://github.com/imageshoporg/Craft/blob/main/README.md",
        "issues": "https://github.com/imageshoporg/Craft/issues"
    },
    "license": "proprietary",
    "authors": [
        {
            "name": "Imageshop",
            "homepage": "https://www.imageshop.org"
        }
    ],
    "require": {
        "craftcms/cms": "^4.0.0 || ^5.0.0"
    },
    "autoload": {
        "psr-4": {
          "Imageshop\\Imageshop\\": "src/"
        }
    },
    "extra": {
        "name": "Imagehop DAM",
        "handle": "imageshop-da",
        "developer": "Imageshop",
        "developerUrl": "https://www.imageshop.org",
        "changelogUrl": "https://raw.githubusercontent.com/imageshoporg/Craft/main/CHANGELOG.md",
        "class": "Imageshop\\Imageshop\\ImageShop"
    }
}
